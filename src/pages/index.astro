---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => !p.id.startsWith('_'))
  .sort((a, b) => {
    if (a.data.order !== undefined && b.data.order !== undefined)
      return a.data.order - b.data.order;
    return a.data.title.localeCompare(b.data.title);
  });
---

<BaseLayout title="Street Knowledge — Cornell Tech">
  <Header />
  <main>
    <div class="page-layout">
      <div class="page-left">
        <section class="hero">
          <h1>Street Knowledge</h1>
          <p class="subtitle">Urban systems design in NYC's Gowanus district</p>
        </section>

        <section class="about">
          <p>
            How can human-centered design processes coupled with modern technologies support urban design? In this seminar, student teams develop evidence-based, data-driven strategies for New York City's Business Improvement Districts — proposing forward-thinking interventions across sustainability, mobility, equity, and resilience. Each project moves through four lenses:
          </p>
          <div class="lenses">
            <div class="lens">
              <p class="lens-number">01</p>
              <p class="lens-title">Insight</p>
              <p class="lens-desc">Understanding the current state through data collection, mapping, and urban analytics</p>
            </div>
            <div class="lens">
              <p class="lens-number">02</p>
              <p class="lens-title">Transformation</p>
              <p class="lens-desc">Proposing iterative, collaborative methods for urban intervention and scenario testing</p>
            </div>
            <div class="lens">
              <p class="lens-number">03</p>
              <p class="lens-title">Prediction</p>
              <p class="lens-desc">Forecasting impact through simulation, agent modeling, and generative methods</p>
            </div>
            <div class="lens">
              <p class="lens-number">04</p>
              <p class="lens-title">Consensus</p>
              <p class="lens-desc">Designing public-facing processes for collaborative decision-making</p>
            </div>
          </div>
        </section>
      </div>

      <div class="page-right">
        <ProjectGrid projects={projects} />
        <p class="radial-heading">Spring 2026 Projects</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
