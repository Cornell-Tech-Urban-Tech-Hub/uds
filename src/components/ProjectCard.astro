---
interface Props {
  title: string;
  members: string[];
  image: string;
  url: string;
  description?: string;
}

const { title, members, image, url, description } = Astro.props;
const imageSrc = `${import.meta.env.BASE_URL}${image}`;
---

<a href={url} class="project-card" target="_blank" rel="noopener noreferrer">
  <div class="card-image">
    <img src={imageSrc} alt={title} loading="lazy" />
    <div class="card-overlay"></div>
  </div>
  <h2 class="card-title">{title}</h2>
  {description && <p class="card-description">{description}</p>}
  <p class="card-members">{members.join(' \u00B7 ')}</p>
</a>
